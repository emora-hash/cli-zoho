                      ],
                      "additionalProperties": true
                    }
                  ]
                }
              }
            }
          }
        },
        "security": [
          {
            "iam-oauth2-schema": [
              "ZohoCRM.settings.modules.UPDATE"
            ]
          }
        ]
      }
    }
