                              "properties": {
                                "status": {
                                  "type": "string",
                                  "enum": [
                                    "error"
                                  ],
                                  "description": "Error status."
                                },
                                "code": {
                                  "type": "string",
                                  "enum": [
                                    "INVALID_DATA"
                                  ],
                                  "description": "Error code for invalid data."
                                },
                                "message": {
                                  "type": "string",
                                  "description": "Error message describing the issue.",
                                  "maxLength": 1000
                                },
                                "details": {
