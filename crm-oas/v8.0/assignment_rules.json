      },
      "IdSchema": {
        "type": "string",
        "description": "ID of the resource",
        "pattern": "^[1-9][0-9]{0,18}$",
        "minLength": 1,
        "maxLength": 19
      },
      "ErrorResponseModuleNotSupported": {
        "type": "object",
