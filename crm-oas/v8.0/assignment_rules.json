          "status"
        ],
        "title": "Module Not Supported Error Response"
      },
      "ResourceResponseObject": {
        "type": "object",
        "additionalProperties": true,
        "description": "Resource details",
        "properties": {
          "name": {
            "type": "string",
            "description": "Display name of the resource",
            "maxLength": 255
          },
          "id": {
            "description": "Id of the resource",
