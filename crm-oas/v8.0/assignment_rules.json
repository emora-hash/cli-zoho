          },
          "resources": {
            "type": "array",
            "description": "List of action details of the given type",
            "items": {
              "$ref": "#/components/schemas/ResourceResponseObject"
            },
            "maxItems": 1,
            "minItems": 1
          }
        },
        "required": [
          "type"
        ],
        "title": "Followup actions response object"
      },
