            "name": "module",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string",
              "maxLength": 255,
              "description": "CRM module name from which enrichment is triggered."
            },
            "description": "CRM module name from which enrichment is triggered."
          },
          {
