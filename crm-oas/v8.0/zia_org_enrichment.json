                      "items": {
                        "type": "object",
                        "description": "Organization enrichment job object",
                        "additionalProperties": false,
                        "properties": {
                          "id": {
                            "type": "string",
                            "maxLength": 19,
                            "description": "Enrichment job ID"
                          },
                          "status": {
                            "type": "string",
                            "enum": [
                              "SCHEDULED",
                              "COMPLETED",
                              "DATA_NOT_FOUND",
                              "FAILED"
