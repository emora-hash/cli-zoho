          {
            "iam-oauth2-schema": [
              "ZohoCRM.features.READ"
            ]
          }
        ],
        "parameters": [
          {
            "$ref": "#/components/parameters/Module"
          },
          {
            "$ref": "#/components/parameters/ApiNames"
          },
          {
            "$ref": "#/components/parameters/PerPage"
          },
          {
            "$ref": "#/components/parameters/Page"
          }
        ],
