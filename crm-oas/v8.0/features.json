  "components": {
    "parameters": {
      "Module": {
        "description": "module name",
        "name": "module",
        "in": "query",
        "required": false,
        "schema": {
          "maxLength": 25,
          "type": "string"
        }
      },
      "ApiNames": {
        "description": "Api names of the feature comma separated",
        "name": "api_names",
        "in": "query",
        "required": false,
        "schema": {
          "type": "string",
          "enum": [
            "custom_field",
            "custom_field,encrypt_field,unique_field,private_fields,external_field,personal_health_fields",
            "personal_health_fields",
            "encrypt_field",
            "external_field",
            "unique_field",
