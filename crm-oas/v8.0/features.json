                              "description": "components",
                              "additionalProperties": true,
                              "type": "object",
                              "properties": {
                                "api_name": {
                                  "maxLength": 255,
                                  "description": "API name of the feature",
                                  "type": "string"
                                },
                                "module_supported": {
