          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "description": "Request body for uploading organization photo",
                "additionalProperties": false,
                "properties": {
                  "file": {
                    "type": "object",
                    "description": "The image file to upload as organization photo",
                    "additionalProperties": false
                  }
                },
                "required": [
                  "file"
                ]
              }
            }
          },
          "required": true
        },
        "responses": {
