                    },
                    "message": {
                      "type": "string",
                      "description": "Error message describing the issue",
                      "maxLength": 1000
                    },
                    "details": {
                      "type": "object",
                      "description": "Additional details about the error",
                      "additionalProperties": false,
                      "properties": {}
                    }
                  }
                }
              }
