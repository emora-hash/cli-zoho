                            "success"
                          ]
                        },
                        "code": {
                          "type": "string",
                          "description": "Response code",
                          "enum": [
                            "SUCCESS"
                          ]
                        },
                        "message": {
                          "type": "string",
                          "description": "Success message",
                          "maxLength": 1000
                        },
                        "details": {
                          "type": "object",
                          "description": "Additional details about the operation",
                          "additionalProperties": false,
                          "properties": {}
                        }
                      }
                    }
                  ]
                }
              }
            }
          },
