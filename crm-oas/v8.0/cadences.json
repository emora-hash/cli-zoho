            "type": "integer",
            "format": "int32",
            "description": "Number of WhatsApp follow-ups"
          },
          "task_follow_up_count": {
            "type": "integer",
            "format": "int32",
            "description": "Number of task follow-ups"
          },
          "call_follow_up_count": {
            "type": "integer",
