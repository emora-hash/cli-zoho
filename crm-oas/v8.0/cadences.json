          "description": "Cadence id in url path",
          "schema": {
            "type": "string",
            "maxLength": 255
          }
        }
      ]
    },
    "/settings/automation/cadences/{id}/actions/activate": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "description": "Cadence id in url path",
          "schema": {
            "type": "string",
            "maxLength": 255
          }
        }
      ]
    },
    "/settings/automation/cadences/{id}/actions/deactivate": {
      "parameters": [
        {
          "name": "id",
