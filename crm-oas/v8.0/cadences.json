          "description": "Cadence id in url path",
          "schema": {
            "type": "string",
            "maxLength": 255
          }
        }
      ]
    },
    "/settings/automation/cadences/{id}/actions/publish": {
      "parameters": [
        {
          "name": "id",
          "in": "path",
          "required": true,
          "description": "Cadence id in url path",
          "schema": {
            "type": "string",
            "maxLength": 255
          }
        }
      ]
    }
  },
